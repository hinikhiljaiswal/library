{
  "name": "library-seat-booking",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "clean:web": "rm -rf apps/web/.next",
    "dev": "if [ \"$RENDER\" = \"true\" ] || [ \"$NODE_ENV\" = \"production\" ]; then npm run start:web; else npm run clean:web && (npm run dev:api & npm run dev:web); fi",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web run build",
    "start:api": "npm --workspace apps/api run start",
    "start:web": "npm --workspace apps/web run start",
    "render:api:build": "npm install --include=dev && npm run build:api",
    "render:api:start": "npm run start:api",
    "render:web:build": "npm install --include=dev && npm run build:web",
    "render:web:start": "npm run start:web",
    "start": "npm run start:web",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint"
  }
}
